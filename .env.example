# Copy to .env and fill in.

# PUBLIC (frontend-safe). Use the publishable / anon key here.
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# SERVER-ONLY secret key — powers admin account-creation. Never exposed to the
# browser. Required in Vercel too (as a normal server env var).
SUPABASE_SERVICE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Used ONLY by `npm run migrate` (local DB migrations). Not needed in Vercel.
# URL-encode special characters in the password (e.g. @ -> %40).
SUPABASE_DB_URL=postgresql://postgres.YOURPROJECT:PASSWORD@aws-...pooler.supabase.com:5432/postgres
